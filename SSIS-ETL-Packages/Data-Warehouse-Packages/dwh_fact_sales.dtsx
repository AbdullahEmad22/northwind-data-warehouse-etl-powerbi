                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
	o.order_id, o.customer_id, o.employee_id, o.order_date,
	o.required_date, o.shipped_date, o.ship_via AS shipper_id,
	o.freight, o.ship_city, o.ship_country, o.ship_region,
	od.product_id, od.unit_price, od.quantity, od.discount,
	p.supplier_id
FROM stg.orders AS o
INNER JOIN stg.order_details AS od
ON o.order_id = od.order_id
INNER JOIN stg.products AS p
ON od.product_id = p.product_id;</property>
